    "tip.ifthen1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Research shows \"If X, then Y\" is effective for habit formation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「もし◯◯したら、◯◯する」という書き方は習慣化に効果的だと研究で示されています。"
          }
        }
      }
    },
    "tip.value1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"I value…\" has research-backed effects on resilience under stress."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「◯◯を大切にしたい」という書き方は、ストレス時に強くなる効果が研究で示されています。"
          }
        }
      }
    },
    "tip.production": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading aloud sticks better in memory than reading silently."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "声に出して読むと、目で読むより記憶に残りやすいことが分かっています。"
          }
        }
      }
    },
    "tip.short": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Short is fine. The length you can sustain is best."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短い言葉でもOK。続けられる長さが一番です。"
          }
        }
      }
    },
    "tip.streak": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your streak breaks, just start again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ストリークが途切れても、また始めれば大丈夫です。"
          }
        }
      }
    },
    "tip.consistency": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Consistency over perfection. A little today is enough."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完璧より継続。今日も少しでもOKです。"
          }
        }
      }
    },
    "tip.ifthen2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Concrete triggers like \"When I wake up…\" help things stick."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「朝起きたら...」「会社に着いたら...」のように具体的な状況から書くと続きやすいです。"
          }
        }
      }
    },
    "tip.value2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaffirming your core values softens defensive reactions, research shows."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分が大切にしている価値を確認するだけで、防衛反応が和らぐ研究があります。"
          }
        }
      }
    },
