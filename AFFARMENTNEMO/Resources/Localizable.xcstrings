    "help.tip1.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading aloud yourself sticks in memory better than listening."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分で声に出して読む方が、聞くより記憶に定着しやすいことが研究で示されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading aloud yourself sticks in memory better than listening."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading aloud yourself sticks in memory better than listening."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading aloud yourself sticks in memory better than listening."
          }
        }
      }
    },
