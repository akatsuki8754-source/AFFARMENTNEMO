    "tip.ifthen1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Research shows \"If X, then Y\" is effective for habit formation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「もし◯◯したら、◯◯する」という書き方は習慣化に効果的だと研究で示されています。"
          }
