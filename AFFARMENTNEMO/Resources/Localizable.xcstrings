    "help.intro": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is based on psychological research. You don't need to read this to benefit. Read on if interested."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは、心理学研究をベースに設計されています。難しい話は読まなくても効果は出ます。興味があれば読んでみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is based on psychological research. You don't need to read this to benefit. Read on if interested."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is based on psychological research. You don't need to read this to benefit. Read on if interested."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
