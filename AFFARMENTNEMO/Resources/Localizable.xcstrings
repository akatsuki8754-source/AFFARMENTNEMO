            "value": "Effects vary by individual"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "効果は個人差があります"
          }
        }
      }
    },
    "help.tip4.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If it doesn't feel right, take a break, change it, or delete it. Use it at your own pace."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "合わないと感じたら、休んでも、変えても、削除してもOK。自分のペースで使ってください。"
          }
        }
      }
    },
    "help.disclaimer": {
