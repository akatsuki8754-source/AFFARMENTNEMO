    "welcome.sub": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write your wishes and goals, revisit them daily. Get energy from others' words. That's what this app is."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の願いや目標を書いて、毎日見返す。みんなの願いや想いをみて元気をもらう。そんなアプリです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Write your wishes and goals, revisit them daily. Get energy from others' words. That's what this app is."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Write your wishes and goals, revisit them daily. Get energy from others' words. That's what this app is."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Write your wishes and goals, revisit them daily. Get energy from others' words. That's what this app is."
          }
        }
      }
    },
