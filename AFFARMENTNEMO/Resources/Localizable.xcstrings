    "help.tip3.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"If X, then Y\" is strongest"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「もし◯◯したら、◯◯する」が最強"
          }
        },
        "zh-Hans": {
