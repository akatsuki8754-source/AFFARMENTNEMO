    "splash.tagline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change yourself with your own words."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の言葉で、自分を変える。"
