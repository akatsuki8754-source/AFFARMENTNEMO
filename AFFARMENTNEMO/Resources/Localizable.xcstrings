    "help.tip2.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"…want to\" or \"…value\" is safer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「〜したい」「〜を大切にしたい」が安全"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\"…want to\" or \"…value\" is safer"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\"…want to\" or \"…value\" is safer"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"…want to\" or \"…value\" is safer"
          }
        }
      }
    },
    "help.tip2.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong assertions like \"I am perfect\" can backfire when they conflict with how you actually feel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「私は完璧だ」のような断定は、自分の気持ちと矛盾していると逆に気分が下がる、という研究もあります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong assertions like \"I am perfect\" can backfire when they conflict with how you actually feel."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong assertions like \"I am perfect\" can backfire when they conflict with how you actually feel."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong assertions like \"I am perfect\" can backfire when they conflict with how you actually feel."
          }
        }
      }
    },
