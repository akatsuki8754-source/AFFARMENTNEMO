    "help.intro": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is based on psychological research. You don't need to read this to benefit. Read on if interested."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは、心理学研究をベースに設計されています。難しい話は読まなくても効果は出ます。興味があれば読んでみてください。"
          }
        }
      }
    },
    "help.tip1.num": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1."
          }
        }
      }
    },
    "help.tip1.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read aloud"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "声に出して読みましょう"
          }
        }
      }
    },
    "help.tip1.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading aloud yourself sticks in memory better than listening."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分で声に出して読む方が、聞くより記憶に定着しやすいことが研究で示されています。"
          }
        }
      }
    },
    "help.tip1.cite": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Source: MacLeod & Forrin, Production Effect"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "出典: MacLeod & Forrin, Production Effect"
          }
        }
      }
    },
    "help.tip2.num": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2."
          }
        }
      }
    },
    "help.tip2.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"…want to\" or \"…value\" is safer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「〜したい」「〜を大切にしたい」が安全"
          }
        }
      }
    },
    "help.tip2.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong assertions like \"I am perfect\" can backfire when they conflict with how you actually feel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「私は完璧だ」のような断定は、自分の気持ちと矛盾していると逆に気分が下がる、という研究もあります。"
          }
        }
      }
    },
    "help.tip2.cite": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Source: Wood et al. 2009"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "出典: Wood et al. 2009"
          }
        }
      }
    },
    "help.tip3.num": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "3."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "3."
          }
        }
      }
    },
    "help.tip3.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"If X, then Y\" is strongest"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「もし◯◯したら、◯◯する」が最強"
          }
        }
      }
    },
    "help.tip3.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In goal-achievement meta-analyses, this is the strongest format with effect size d=.65."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "目標達成研究のメタ分析で最も強力な手法とされ、効果サイズ d=.65 の中〜大効果が確認されています。"
          }
        }
      }
    },
    "help.tip3.cite": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Source: Gollwitzer 1999"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "出典: Gollwitzer 1999"
          }
        }
      }
    },
    "help.tip4.num": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "4."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "4."
          }
        }
      }
    },
    "help.tip4.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Effects vary by individual"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "効果は個人差があります"
          }
        }
      }
    },
    "help.tip4.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If it doesn't feel right, take a break, change it, or delete it. Use it at your own pace."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "合わないと感じたら、休んでも、変えても、削除してもOK。自分のペースで使ってください。"
          }
        }
      }
    },
    "help.disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is not a medical service. If you feel unwell, please consult a professional."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは医療行為ではありません。心身の不調を感じたら、専門家にご相談ください。"
          }
        }
      }
