    "welcome.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ようこそ"
          }
        }
      }
    },
    "welcome.sub": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write your wishes and goals, revisit them daily. Get energy from others' words. That's what this app is."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の願いや目標を書いて、毎日見返す。みんなの願いや想いをみて元気をもらう。そんなアプリです。"
          }
        }
      }
    },
    "welcome.bullet1.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Completely free"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完全無料です"
          }
        }
      }
    },
    "welcome.bullet1.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No purchases, no subscriptions"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "課金もサブスクもありません"
          }
        }
      }
    },
    "welcome.bullet2.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A space without negativity"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "批判のない場所です"
          }
        }
      }
    },
    "welcome.bullet2.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No comments, no likes. Other people's words drift by quietly."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コメントもいいねもありません。みんなの言葉も静かに流れてきます。"
          }
        }
      }
    },
    "welcome.bullet3.title": {
      "extractionState": "manual",
