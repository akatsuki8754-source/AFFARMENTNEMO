rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザー個人データ: 本人のみ読み書き
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /affirmations/{affirmationId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /readLogs/{dateKey} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /blocks/{targetUid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 流すだけタイムライン: 認証済みユーザーが読み取り可、本人による投稿のみ可、削除不可
    match /timelineRooms/{room}/posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 100
                    && request.resource.data.languageRoom == room
                    && request.resource.data.expireAt is timestamp
                    && request.resource.data.expireAt > request.time
                    && request.resource.data.expireAt < request.time + duration.value(25, 'h');
      allow update: if request.auth != null
                    && (
                      (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['reportedBy','reportCount'])
                      )
                      ||
                      (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['reactionLike','reactionHeart','reactionPeace','reactedBy'])
                      )
                      ||
                      (
                        request.auth.uid == resource.data.authorUid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isHidden'])
                        && request.resource.data.isHidden == true
                      )
                    );
      allow delete: if false;
    }

    // 通報: 作成のみ、自分の uid と一致
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false;
    }

    // AIランタイム設定: クライアントは有効/無効だけ読む。変更は管理者/Functionsのみ。
    match /system/{docId} {
      allow read: if request.auth != null
                  && docId in ['aiRuntime', 'aiBudgetAlert'];
      allow write: if false;
    }
  }
}
